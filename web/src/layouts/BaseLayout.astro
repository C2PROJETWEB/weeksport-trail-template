---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const { site, nav, title, description } = Astro.props
const primaryColor = site?.couleurPrimaire || '#E63946'
const secondaryColor = site?.couleurSecondaire || '#1D3557'
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title || site?.name}</title>
  <meta name="description" content={description || site?.metaDescription || ''} />
  <style define:vars={{ primaryColor, secondaryColor }}>
    :root {
      --color-primary: var(--primaryColor);
      --color-secondary: var(--secondaryColor);
    }
  </style>
</head>
<body class="bg-white text-gray-800 font-sans">
  <Header site={site} nav={nav} />
  <main>
    <slot />
  </main>
  <Footer site={site} />
</body>
</html>
