---
import { urlFor, fileUrl } from '../lib/sanity'
import { toHTML } from '@portabletext/to-html'
const { sections = [], raceTabs = null, currentSlug = '', documentsGlobaux = [] } = Astro.props

// Résout les docs d'une section (locaux + références bibliothèque)
function resolveDocs(sectionDocs: any[]) {
  return (sectionDocs || []).map((doc: any) => {
    if (doc._globalRef) {
      const global = documentsGlobaux.find((d: any) => d._key === doc._globalRef)
      return global ? { ...doc, ...global } : doc
    }
    return doc
  }).filter((d: any) => d?.asset)
}

const toHTMLOptions = {
  components: {
    types: {
      blocBouton: ({ value }: any) => {
        const cls = value.style === 'outline' ? 'btn-outline' : 'btn-primary'
        const target = value.externe ? ' target="_blank" rel="noopener"' : ''
        return `<div class="not-prose mt-6"><a href="${value.url || '#'}" class="${cls}"${target}>${value.label || 'Bouton'}</a></div>`
      }
    }
  }
}

// Attach the next sectionTexte to a single-epreuve section so we can render them together
const processed: any[] = []
const skipped = new Set<number>()
sections.forEach((section: any, i: number) => {
  if (section._type === 'sectionEpreuves' && section.epreuves?.length === 1) {
    const next = sections[i + 1]
    if (next?._type === 'sectionTexte') {
      processed.push({ ...section, _linkedTexte: next })
      skipped.add(i + 1)
      return
    }
  }
  if (!skipped.has(i)) processed.push(section)
})
---

{processed.map((section: any) => {

  // ─── TEXTE ───────────────────────────────────────────────
  if (section._type === 'sectionTexte') {
    const dispo: string = section.disposition || 'image_dessous'
    const imgs: any[] = section.images || []
    const hasImages = imgs.length > 0
    const firstImg = imgs[0] || null
    const isSide = dispo === 'image_droite' || dispo === 'image_gauche'
    const html = section.contenu ? toHTML(section.contenu, toHTMLOptions) : ''
    return (
      <section class="py-24 px-6 max-w-5xl mx-auto">
        <div class="reveal">

          {/* ── Image au-dessus ── */}
          {dispo === 'image_dessus' && hasImages && (
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
              {imgs.map((img: any) => (
                <figure class="overflow-hidden rounded group">
                  <img src={urlFor(img).width(800).height(560).url()} alt={img.caption||''}
                    class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>
                  {img.caption && <figcaption class="text-xs text-gray-400 mt-1 px-1">{img.caption}</figcaption>}
                </figure>
              ))}
            </div>
          )}

          {/* ── Côte à côte ── */}
          {isSide && firstImg ? (
            <div class={`flex flex-col gap-10 items-center ${dispo === 'image_gauche' ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <div class="w-full md:w-1/2 shrink-0">
                <figure class="overflow-hidden rounded-xl shadow-md group">
                  <img src={urlFor(firstImg).width(900).height(620).url()} alt={firstImg.caption||''}
                    class="w-full h-72 md:h-96 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>
                </figure>
              </div>
              <div class="w-full md:w-1/2">
                {section.titre && <div class="mb-8"><span class="deco-line"></span><h2 class="section-title mt-4">{section.titre}</h2></div>}
                {html && <div class="prose prose-gray prose-lg max-w-none prose-headings:font-display prose-headings:tracking-wide prose-a:text-[var(--color-primary)] prose-headings:text-gray-900 prose-p:text-gray-600" set:html={html}/>}
                {section.boutons?.length > 0 && (
                  <div class="flex flex-wrap gap-3 mt-8">
                    {(section.boutons as any[]).map((btn: any) => (
                      <a href={btn.url||'#'} class={btn.style==='outline'?'btn-outline':'btn-primary'}
                        target={btn.externe?'_blank':'_self'} rel={btn.externe?'noopener noreferrer':''}>{btn.label}</a>
                    ))}
                  </div>
                )}
                {resolveDocs(section.documents).length > 0 && (
                  <div class="mt-6 space-y-2">
                    {resolveDocs(section.documents).map((doc: any) => {
                      const url = fileUrl(doc.asset)
                      return (
                        <a href={url} target="_blank" rel="noopener"
                          class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 hover:bg-gray-100 hover:border-gray-300 transition group text-sm font-medium text-gray-700">
                          <span class="text-xl shrink-0">📎</span>
                          <span class="flex-1 truncate">{doc.nom || 'Document'}</span>
                          <span class="text-xs text-gray-400 group-hover:text-gray-600 shrink-0">Télécharger ↓</span>
                        </a>
                      )
                    })}
                  </div>
                )}
              </div>
            </div>
          ) : (
            /* ── Texte seul / dessus / dessous ── */
            <div class="max-w-4xl mx-auto">
              {section.titre && <div class="mb-10"><span class="deco-line"></span><h2 class="section-title mt-4">{section.titre}</h2></div>}
              {html && <div class="prose prose-gray prose-lg max-w-none prose-headings:font-display prose-headings:tracking-wide prose-a:text-[var(--color-primary)] prose-headings:text-gray-900 prose-p:text-gray-600" set:html={html}/>}
              {dispo === 'image_dessous' && hasImages && (
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-10">
                  {imgs.map((img: any) => (
                    <figure class="overflow-hidden rounded group">
                      <img src={urlFor(img).width(800).height(560).url()} alt={img.caption||''}
                        class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>
                      {img.caption && <figcaption class="text-xs text-gray-400 mt-1 px-1">{img.caption}</figcaption>}
                    </figure>
                  ))}
                </div>
              )}
              {section.boutons?.length > 0 && (
                <div class="flex flex-wrap gap-3 mt-8">
                  {(section.boutons as any[]).map((btn: any) => (
                    <a href={btn.url||'#'} class={btn.style==='outline'?'btn-outline':'btn-primary'}
                      target={btn.externe?'_blank':'_self'} rel={btn.externe?'noopener noreferrer':''}>{btn.label}</a>
                  ))}
                </div>
              )}
              {section.documents?.length > 0 && (
                <div class="mt-8 space-y-2">
                  {(section.documents as any[]).map((doc: any) => {
                    const url = doc.asset ? fileUrl(doc.asset) : null
                    if (!url) return null
                    return (
                      <a href={url} target="_blank" rel="noopener"
                        class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 hover:bg-gray-100 hover:border-gray-300 transition group text-sm font-medium text-gray-700">
                        <span class="text-xl shrink-0">📎</span>
                        <span class="flex-1 truncate">{doc.nom || 'Document'}</span>
                        <span class="text-xs text-gray-400 group-hover:text-gray-600 shrink-0">Télécharger ↓</span>
                      </a>
                    )
                  })}
                </div>
              )}
            </div>
          )}

        </div>
      </section>
    )
  }

  // ─── COMPTE À REBOURS ────────────────────────────────────
  if (section._type === 'sectionCompteur') return (
    <section id="compteur" class="py-24 px-6 border-t border-gray-100">
      <div class="max-w-5xl mx-auto text-center">
        <div class="reveal mb-16">
          <span class="section-label mx-auto block text-center">{section.titre || 'Prochaine édition'}</span>
          <span class="deco-line mx-auto"></span>
        </div>
        <div
          id="countdown"
          class="flex items-center justify-center gap-4 md:gap-12"
          data-date={section.dateEpreuve}
        >
          {[
            { id: 'cd-jours', label: 'Jours' },
            { id: 'cd-heures', label: 'Heures' },
            { id: 'cd-min', label: 'Min' },
            { id: 'cd-sec', label: 'Sec' }
          ].map(({ id, label }) => (
            <div class="flex flex-col items-center">
              <span
                class="font-display text-6xl md:text-8xl lg:text-9xl text-white tabular-nums"
                id={id}
                style="color: var(--color-primary)"
              >--</span>
              <span class="text-xs uppercase tracking-[0.3em] text-gray-400 mt-3">{label}</span>
            </div>
          ))}
        </div>
        <p class="text-gray-400 text-xs mt-12 uppercase tracking-widest">Cap sur la 7ème édition</p>
      </div>
    </section>
  )

  // ─── ÉPREUVES ─────────────────────────────────────────────
  if (section._type === 'sectionEpreuves') {
    const epreuves = section.epreuves || []

    // Page d'épreuve individuelle : galerie + carte + navigation en bas
    if (epreuves.length === 1) {
      const e = epreuves[0]
      const imgSrc = e.image ? urlFor(e.image).width(1400).height(800).url() : (e.imageUrl || null)
      const linkedTexte = section._linkedTexte
      return (
        <section>

          {/* ── Fil d'Ariane ── */}
          <div class="max-w-7xl mx-auto px-6 md:px-12 pt-10 pb-0">
            <a href="/les-epreuves" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--color-primary)] transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              Les Épreuves
            </a>
          </div>

          {/* ── Hero : photo + titre + stats ── */}
          <div class="relative mt-6 overflow-hidden" style="height: 58vh; min-height: 420px">
            {imgSrc && (
              <img src={imgSrc} alt={e.nom} class="w-full h-full object-cover" loading="eager" />
            )}
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(20,18,32,0.97) 0%, rgba(0,0,0,0.45) 55%, rgba(0,0,0,0.1) 100%)" />
            <div class="absolute bottom-0 left-0 right-0 px-6 md:px-12 pb-10">
              <div class="max-w-7xl mx-auto">
                <h1 class="font-display text-5xl md:text-7xl lg:text-8xl uppercase text-white leading-none mb-5">{e.nom}</h1>
                <div class="flex flex-wrap items-center gap-3">
                  {e.distance && (
                    <span class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-wider px-4 py-2.5"
                      style="color: var(--color-primary); background: rgba(0,0,0,0.7); border: 1px solid var(--color-primary)">
                      {e.distance}
                    </span>
                  )}
                  {e.denivele && (
                    <span class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-wider px-4 py-2.5 text-white"
                      style="background: rgba(0,0,0,0.7); border: 1px solid rgba(255,255,255,0.2)">
                      ↑ {e.denivele}
                    </span>
                  )}
                  {e.depart && (
                    <span class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-wider px-4 py-2.5 text-white"
                      style="background: rgba(0,0,0,0.7); border: 1px solid rgba(255,255,255,0.2)">
                      ⏱ Départ {e.depart}
                    </span>
                  )}
                  {e.lienInscription && (
                    <a href={e.lienInscription} target="_blank" rel="noopener" class="btn-primary ml-2">
                      S'inscrire
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* ── Description ── */}
          {linkedTexte?.contenu && (
            <div class="max-w-4xl mx-auto px-6 md:px-12 py-16">
              <div
                class="prose prose-gray prose-lg max-w-none prose-headings:font-display prose-headings:tracking-wide prose-a:text-[var(--color-primary)] prose-p:text-gray-600 prose-headings:text-gray-900 prose-strong:text-gray-900 prose-li:text-gray-600"
                set:html={toHTML(linkedTexte.contenu, toHTMLOptions)}
              />
            </div>
          )}

          {/* ── Galerie photos ── */}
          {e.photos?.length > 0 && (
            <div class="max-w-7xl mx-auto px-6 md:px-12 pb-16">
              <span class="section-label mb-6 block">Photos</span>
              <div class="grid grid-cols-2 gap-3">
                {(e.photos as any[]).slice(0, 4).map((photo: any) => {
                  const src = typeof photo === 'string'
                    ? photo
                    : (photo.image ? urlFor(photo.image).width(900).height(600).url() : photo.url)
                  return src ? (
                    <div class="overflow-hidden">
                      <img src={src} alt="" class="w-full h-64 md:h-80 object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
                    </div>
                  ) : null
                })}
              </div>
            </div>
          )}

          {/* ── Carte du parcours ── */}
          {e.openrunnerUrl && (
            <div class="max-w-7xl mx-auto px-6 md:px-12 pb-16">
              <span class="section-label mb-6 block">Parcours</span>
              <div class="overflow-hidden border border-gray-200">
                <iframe
                  src={e.openrunnerUrl}
                  width="100%"
                  height="650"
                  loading="lazy"
                  style="border: none; display: block"
                  title={`Parcours ${e.nom}`}
                />
              </div>
            </div>
          )}

          {/* ── Navigation entre épreuves ── */}
          {raceTabs && raceTabs.length > 0 && (
            <div class="border-t border-gray-100 py-16 px-6 md:px-12">
              <div class="max-w-7xl mx-auto">
                <span class="section-label mb-8 block">Toutes les épreuves</span>
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
                  {raceTabs.map((tab: any) => (
                    <a
                      href={`/${tab.slug}`}
                      class="p-5 border transition-all duration-300 text-sm font-bold uppercase tracking-wider block text-center"
                      style={tab.slug === currentSlug
                        ? `border-color: var(--color-primary); color: var(--color-primary); background: rgba(var(--color-primary-rgb), 0.06)`
                        : 'border-color: rgba(0,0,0,0.1); color: rgba(0,0,0,0.4)'}
                      onmouseover={tab.slug !== currentSlug ? "this.style.borderColor='rgba(0,0,0,0.25)'; this.style.color='#111'; this.style.background='rgba(0,0,0,0.03)'" : ''}
                      onmouseout={tab.slug !== currentSlug ? "this.style.borderColor='rgba(0,0,0,0.1)'; this.style.color='rgba(0,0,0,0.4)'; this.style.background=''" : ''}
                    >
                      {tab.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          )}

        </section>
      )
    }

    // Grille multi-épreuves (page d'accueil / les-epreuves)
    return (
      <section id="epreuves" class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="reveal mb-16">
            <span class="section-label">{section.titre || 'Les épreuves'}</span>
            <span class="deco-line"></span>
            <h2 class="section-title">Les <span>Courses</span></h2>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {epreuves.map((e, i) => (
              <div class={`epreuve-card reveal reveal-delay-${Math.min(i+1,4)} relative group`}>
                {e.lienPage && (
                  <a href={e.lienPage} class="absolute inset-0 z-10" aria-label={`Découvrir ${e.nom}`} />
                )}
                {(e.image || e.imageUrl) && (
                  <div class="relative h-52 overflow-hidden">
                    <img
                      src={e.image ? urlFor(e.image).width(700).height(500).url() : e.imageUrl}
                      alt={e.nom}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="card-overlay absolute inset-0 opacity-0 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(var(--color-primary-rgb),0.3), transparent)" />
                  </div>
                )}
                <div class="p-6">
                  <h3 class="font-display text-3xl tracking-wide text-gray-900 mb-3">{e.nom}</h3>
                  <div class="flex gap-4 mb-4">
                    {e.distance && (
                      <div class="flex items-center gap-1.5 text-sm font-semibold" style="color: var(--color-primary)">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                        {e.distance}
                      </div>
                    )}
                    {e.denivele && (
                      <div class="flex items-center gap-1.5 text-sm font-semibold text-gray-500">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7M12 3v18"/></svg>
                        {e.denivele}
                      </div>
                    )}
                  </div>
                  {e.description && <p class="text-sm text-gray-500 leading-relaxed mb-5">{e.description}</p>}
                  {e.lienPage && (
                    <span class="text-xs font-bold uppercase tracking-widest text-gray-400 group-hover:text-[color:var(--color-primary)] transition-colors">
                      Découvrir →
                    </span>
                  )}
                  {e.lienInscription && !e.lienPage && (
                    <a href={e.lienInscription} class="btn-primary text-xs py-3 px-5 inline-flex relative z-20" target="_blank" rel="noopener">
                      S'inscrire
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  // ─── PROGRAMME ────────────────────────────────────────────
  if (section._type === 'sectionProgramme') {
    const bgImg = section.image
      ? urlFor(section.image).width(1920).url()
      : (section.imageUrl || null)
    return (
      <section id="programme" class="relative py-32 px-6 bg-white">
        <div class="absolute left-0 top-0 bottom-0 w-1 overflow-hidden">
          <div class="w-full h-full" style="background: linear-gradient(to bottom, transparent, var(--color-primary), transparent)" />
        </div>
        <div class="relative z-10 max-w-4xl mx-auto">
          <div class="reveal mb-12">
            <span class="section-label">{section.titre || 'Le Programme'}</span>
            <span class="deco-line"></span>
            <h2 class="section-title">Un programme <span>XXL</span></h2>
          </div>
          {section.contenu && (
            <div
              class="prose prose-lg max-w-none prose-headings:font-display prose-headings:tracking-wide prose-a:text-[var(--color-primary)] prose-p:text-gray-600 prose-strong:text-gray-900"
              set:html={toHTML(section.contenu, toHTMLOptions)}
            />
          )}
        </div>
      </section>
    )
  }

  // ─── GALERIE ──────────────────────────────────────────────
  if (section._type === 'sectionGalerie') return (
    <section id="galerie" class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="reveal mb-12">
          <span class="section-label">Photos</span>
          <span class="deco-line"></span>
          <h2 class="section-title">{section.titre || 'La <span>Galerie</span>'}</h2>
        </div>
        <div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3">
          {section.photos?.map((photo, i) => (
            <div class={`break-inside-avoid overflow-hidden reveal reveal-delay-${Math.min(i%4+1,4)} group cursor-pointer`}>
              <div class="relative overflow-hidden">
                <img
                  src={urlFor(photo).width(700).url()}
                  alt={photo.caption || ''}
                  class="w-full transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center" style="background: rgba(var(--color-primary-rgb),0.3)">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── PHOTOS PAR ANNÉE ─────────────────────────────────────
  if (section._type === 'sectionPhotos') return (
    <section id="photos" class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="reveal mb-16">
          <span class="section-label">{section.titre || 'Photos'}</span>
          <span class="deco-line"></span>
          <h2 class="section-title">La <span>Galerie</span></h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.annees?.map((a, i) => {
            const thumbUrl = a.image
              ? urlFor(a.image).width(800).height(500).url()
              : (a.imageUrl || null)
            return (
              <a
                href={a.lien || '#'}
                target={a.lien ? '_blank' : undefined}
                rel="noopener"
                class={`group relative overflow-hidden reveal reveal-delay-${Math.min(i+1,4)} block`}
                style="min-height: 240px"
              >
                {thumbUrl
                  ? <img src={thumbUrl} alt={`Photos ${a.annee}`} class="w-full h-60 object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                  : <div class="w-full h-60" style="background: var(--color-secondary)" />
                }
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent" />
                <div class="absolute bottom-0 left-0 p-6 flex items-end justify-between w-full">
                  <div>
                    <span class="font-display text-6xl text-white/20 group-hover:text-white/40 transition-colors leading-none block">{a.annee}</span>
                    <span class="text-xs font-bold uppercase tracking-widest text-white/50 group-hover:text-white transition-colors">Voir les photos</span>
                  </div>
                  <svg class="w-5 h-5 text-white/30 group-hover:text-[var(--color-primary)] transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </div>
              </a>
            )
          })}
        </div>
      </div>
    </section>
  )

  // ─── PARTENAIRES ─────────────────────────────────────────
  if (section._type === 'sectionPartenaires') {
    const isAgence = section.groupe === 'agence'
    return (
      <section id={isAgence ? 'partenaires-agence' : 'partenaires'} class={isAgence ? 'py-16 px-6 border-t border-white/5' : 'py-24 px-6'}>
        <div class="max-w-7xl mx-auto">

          {/* En-tête */}
          <div class="reveal mb-12">
            <span class="section-label">{section.titre || 'Partenaires'}</span>
            {!isAgence && <span class="deco-line"></span>}
            {!isAgence && (
              <h2 class="section-title">Ils nous <span>soutiennent</span></h2>
            )}
            {section.description && (
              <p class="text-gray-500 text-sm mt-3 max-w-xl">{section.description}</p>
            )}
          </div>

          {/* Grille */}
          <div class={`grid gap-4 ${isAgence ? 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4' : 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5'}`}>
            {section.partenaires?.map((p: any, i: number) => {
              const logoSrc = p.logo
                ? urlFor(p.logo).height(120).url()
                : (p.logoUrl || null)
              const cardPadding = isAgence ? 'p-5' : 'p-6'
              const logoHeight = isAgence ? 'h-12' : 'h-16'
              const imgMaxH = isAgence ? 'max-h-12' : 'max-h-16'
              return (
                <a
                  href={p.url || '#'}
                  target={p.url ? '_blank' : undefined}
                  rel="noopener"
                  class={`reveal reveal-delay-${Math.min((i % 5) + 1, 4)} group flex flex-col items-center justify-center gap-3 ${cardPadding} border border-black/6 transition-all duration-300 hover:-translate-y-1`}
                  style="background: #f8f7fc"
                  onmouseover="this.style.borderColor='var(--color-primary)'; this.style.boxShadow='0 6px 24px rgba(0,0,0,0.08)'"
                  onmouseout="this.style.borderColor='rgba(0,0,0,0.06)'; this.style.boxShadow=''"
                >
                  {logoSrc ? (
                    <div class={`${logoHeight} flex items-center justify-center w-full`}>
                      <img
                        src={logoSrc}
                        alt={p.nom}
                        class={`${imgMaxH} max-w-full w-auto object-contain transition-transform duration-300 group-hover:scale-105`}
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class={`${logoHeight} flex items-center justify-center`}>
                      <span class="font-display text-xl text-gray-500 group-hover:text-gray-900 transition-colors text-center leading-tight">{p.nom}</span>
                    </div>
                  )}
                  <span class="text-xs text-gray-400 group-hover:text-gray-700 transition-colors uppercase tracking-wider text-center leading-tight">{p.nom}</span>
                </a>
              )
            })}

            {/* Carte "Devenir partenaire" – seulement sur la section événement */}
            {!isAgence && (
              <a
                href="/contact"
                class="reveal group flex flex-col items-center justify-center gap-3 p-6 border border-dashed border-gray-300 transition-all duration-300 hover:-translate-y-1"
                style="background: rgba(0,0,0,0.01)"
                onmouseover="this.style.borderColor='rgba(var(--color-primary-rgb),0.5)'"
                onmouseout="this.style.borderColor='rgba(0,0,0,0.15)'"
              >
                <div class="h-16 flex items-center justify-center">
                  <svg class="w-8 h-8 text-white/20 group-hover:text-[var(--color-primary)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                  </svg>
                </div>
                <span class="text-xs text-gray-400 group-hover:text-[var(--color-primary)] transition-colors uppercase tracking-wider text-center">Devenir partenaire</span>
              </a>
            )}
          </div>
        </div>
      </section>
    )
  }

  // ─── RÉSULTATS ───────────────────────────────────────────
  if (section._type === 'sectionResultats') return (
    <section id="resultats" class="py-24 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="reveal mb-12">
          <span class="section-label">Palmarès</span>
          <span class="deco-line"></span>
          <h2 class="section-title">{section.titre || '<span>Résultats</span>'}</h2>
        </div>
        <div class="space-y-3">
          {section.annees?.map((a, i) => (
            <a
              href={a.lien || '#'}
              target="_blank"
              class={`flex items-center justify-between p-5 border border-gray-200 hover:border-[var(--color-primary)] transition-all duration-300 group reveal reveal-delay-${Math.min(i+1,4)}`}
            >
              <div class="flex items-center gap-4">
                <span class="font-display text-5xl text-gray-200 group-hover:text-[var(--color-primary)] transition-colors">{a.annee}</span>
                <span class="text-sm font-bold uppercase tracking-widest text-gray-500 group-hover:text-gray-900 transition-colors">Résultats officiels</span>
              </div>
              <svg class="w-5 h-5 text-white/20 group-hover:text-[var(--color-primary)] transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── CONTACT ─────────────────────────────────────────────
  if (section._type === 'sectionContact') return (
    <section id="contact" class="py-24 px-6 border-t border-gray-100">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div class="reveal">
            <span class="section-label">{section.titre || 'Contact'}</span>
            <span class="deco-line"></span>
            <h2 class="section-title">Une <span>question ?</span></h2>
            <div class="space-y-4 mt-8">
              {section.email && (
                <a href={`mailto:${section.email}`} class="flex items-center gap-3 text-gray-500 hover:text-gray-900 transition-colors group">
                  <div class="w-10 h-10 rounded flex items-center justify-center border border-gray-200 group-hover:border-[var(--color-primary)] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <span class="text-sm font-medium">{section.email}</span>
                </a>
              )}
              {section.telephone && (
                <a href={`tel:${section.telephone}`} class="flex items-center gap-3 text-gray-500 hover:text-gray-900 transition-colors group">
                  <div class="w-10 h-10 rounded flex items-center justify-center border border-gray-200 group-hover:border-[var(--color-primary)] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <span class="text-sm font-medium">{section.telephone}</span>
                </a>
              )}
            </div>
          </div>
          <div class="reveal reveal-delay-2">
            <form name="contact" method="POST" data-netlify="true" class="space-y-4">
              <input type="hidden" name="form-name" value="contact" />
              <div class="grid grid-cols-2 gap-4">
                <input type="text" name="nom" placeholder="Nom" required
                  class="bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
                <input type="email" name="email" placeholder="Email" required
                  class="bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
              </div>
              <input type="text" name="sujet" placeholder="Sujet"
                class="bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
              <textarea name="message" placeholder="Votre message" rows="5" required
                class="bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full resize-none"></textarea>
              <button type="submit" class="btn-primary w-full justify-center">
                Envoyer le message
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  )

  // ─── BÉNÉVOLES ───────────────────────────────────────────
  if (section._type === 'sectionBenevoles') return (
    <section id="benevoles" class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="reveal order-2 lg:order-1">
            <span class="section-label">Rejoindre l'aventure</span>
            <span class="deco-line"></span>
            <h2 class="section-title">{section.titre || 'Devenir <span>bénévole</span>'}</h2>
            {section.description && <p class="text-gray-500 leading-relaxed mb-8 text-sm">{section.description}</p>}
            {section.lienInscription && (
              <a href={section.lienInscription} class="btn-primary" target="_blank">
                Je participe
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            )}
          </div>
          {(section.image || section.imageUrl) && (
            <div class="reveal reveal-delay-2 order-1 lg:order-2 overflow-hidden">
              <img
                src={section.image ? urlFor(section.image).width(800).url() : section.imageUrl}
                alt="Bénévoles"
                class="w-full h-80 lg:h-96 object-cover"
              />
            </div>
          )}
        </div>
      </div>
    </section>
  )

  // ─── PUBLICITÉ ───────────────────────────────────────────
  if (section._type === 'sectionPub') {
    const pubs = section.pubs || []
    if (!pubs.length) return null
    const cols = pubs.length === 1 ? 'grid-cols-1' : pubs.length === 2 ? 'grid-cols-2' : 'grid-cols-3'
    return (
      <section class="py-10 px-6 bg-white border-y border-gray-100">
        <div class="max-w-7xl mx-auto">
          {section.titre && (
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-gray-300 mb-5 text-center">{section.titre}</p>
          )}
          <div class={`grid ${cols} gap-4`}>
            {(pubs as any[]).map((pub: any) => {
              const src = pub.image ? urlFor(pub.image).width(1200).url() : (pub.imageUrl || null)
              return src ? (
                <a
                  href={pub.lien || '#'}
                  target={pub.lien ? '_blank' : undefined}
                  rel="noopener"
                  class="block overflow-hidden rounded group"
                >
                  <img
                    src={src}
                    alt={pub.alt || ''}
                    class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                </a>
              ) : null
            })}
          </div>
        </div>
      </section>
    )
  }

  return null
})}

<script>
  // Countdown timer
  const countdownEl = document.getElementById('countdown')
  if (countdownEl) {
    const targetDate = new Date(countdownEl.dataset.date as string).getTime()
    const ids = ['cd-jours', 'cd-heures', 'cd-min', 'cd-sec'] as const

    function updateCountdown() {
      const diff = targetDate - Date.now()
      if (diff <= 0) {
        ids.forEach(id => {
          const el = document.getElementById(id)
          if (el) el.textContent = '00'
        })
        return
      }
      const values = [
        Math.floor(diff / 86400000),
        Math.floor((diff % 86400000) / 3600000),
        Math.floor((diff % 3600000) / 60000),
        Math.floor((diff % 60000) / 1000)
      ]
      ids.forEach((id, i) => {
        const el = document.getElementById(id)
        if (el) el.textContent = String(values[i]).padStart(2, '0')
      })
    }

    updateCountdown()
    setInterval(updateCountdown, 1000)
  }
</script>
