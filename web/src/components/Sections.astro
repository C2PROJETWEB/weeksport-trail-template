---
import { urlFor } from '../lib/sanity'
import { toHTML } from '@portabletext/to-html'
const { sections = [] } = Astro.props
---

{sections.map((section) => {

  // ─── TEXTE ───────────────────────────────────────────────
  if (section._type === 'sectionTexte') return (
    <section class="py-24 px-6 max-w-4xl mx-auto">
      <div class="reveal">
        {section.titre && (
          <div>
            <span class="section-label">{section.titre}</span>
            <span class="deco-line"></span>
          </div>
        )}
        {section.contenu && (
          <div class="prose prose-invert prose-lg max-w-none prose-headings:font-display prose-headings:tracking-wide prose-a:text-[var(--color-primary)]"
            set:html={toHTML(section.contenu)} />
        )}
      </div>
    </section>
  )

  // ─── ÉPREUVES ─────────────────────────────────────────────
  if (section._type === 'sectionEpreuves') return (
    <section id="programme" class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="reveal mb-16">
          <span class="section-label">{section.titre || 'Les épreuves'}</span>
          <span class="deco-line"></span>
          <h2 class="section-title">Les <span>Courses</span></h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.epreuves?.map((e, i) => (
            <div class={`epreuve-card reveal reveal-delay-${Math.min(i+1,4)}`}>
              {e.image && (
                <div class="relative h-52 overflow-hidden">
                  <img
                    src={urlFor(e.image).width(700).height(500).url()}
                    alt={e.nom}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy"
                  />
                  <div class="card-overlay absolute inset-0 opacity-0 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(var(--color-primary-rgb),0.3), transparent)" />
                </div>
              )}
              <div class="p-6">
                <h3 class="font-display text-3xl tracking-wide text-white mb-3">{e.nom}</h3>
                <div class="flex gap-4 mb-4">
                  {e.distance && (
                    <div class="flex items-center gap-1.5 text-sm font-semibold" style="color: var(--color-primary)">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                      {e.distance}
                    </div>
                  )}
                  {e.denivele && (
                    <div class="flex items-center gap-1.5 text-sm font-semibold text-white/50">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7M12 3v18"/></svg>
                      {e.denivele}
                    </div>
                  )}
                </div>
                {e.description && <p class="text-sm text-white/50 leading-relaxed mb-5">{e.description}</p>}
                {e.lienInscription && (
                  <a href={e.lienInscription} class="btn-primary text-xs py-3 px-5 inline-flex" target="_blank">
                    S'inscrire
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── GALERIE ──────────────────────────────────────────────
  if (section._type === 'sectionGalerie') return (
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="reveal mb-12">
          <span class="section-label">Photos</span>
          <span class="deco-line"></span>
          <h2 class="section-title">{section.titre || 'La <span>Galerie</span>'}</h2>
        </div>
        <div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3">
          {section.photos?.map((photo, i) => (
            <div class={`break-inside-avoid overflow-hidden reveal reveal-delay-${Math.min(i%4+1,4)} group cursor-pointer`}>
              <div class="relative overflow-hidden">
                <img
                  src={urlFor(photo).width(700).url()}
                  alt={photo.caption || ''}
                  class="w-full transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center" style="background: rgba(var(--color-primary-rgb),0.3)">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── PARTENAIRES ─────────────────────────────────────────
  if (section._type === 'sectionPartenaires') return (
    <section class="py-24 px-6 border-t border-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="reveal text-center mb-16">
          <span class="section-label text-center block">{section.titre || 'Partenaires'}</span>
          <span class="deco-line mx-auto"></span>
          <h2 class="section-title text-center">Ils nous <span>soutiennent</span></h2>
        </div>
        <div class="flex flex-wrap justify-center items-center gap-10 reveal">
          {section.partenaires?.map((p) => (
            <a href={p.url || '#'} target="_blank" rel="noopener"
              class="group transition-all duration-300 opacity-40 hover:opacity-100 grayscale hover:grayscale-0 filter">
              {p.logo
                ? <img src={urlFor(p.logo).height(70).url()} alt={p.nom} class="h-14 object-contain" />
                : <span class="font-bold text-white/60 group-hover:text-white text-lg">{p.nom}</span>
              }
            </a>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── RÉSULTATS ───────────────────────────────────────────
  if (section._type === 'sectionResultats') return (
    <section class="py-24 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="reveal mb-12">
          <span class="section-label">Palmarès</span>
          <span class="deco-line"></span>
          <h2 class="section-title">{section.titre || '<span>Résultats</span>'}</h2>
        </div>
        <div class="space-y-3">
          {section.annees?.map((a, i) => (
            <a
              href={a.lien || '#'}
              target="_blank"
              class={`flex items-center justify-between p-5 border border-white/10 hover:border-[var(--color-primary)] transition-all duration-300 group reveal reveal-delay-${Math.min(i+1,4)}`}
            >
              <div class="flex items-center gap-4">
                <span class="font-display text-5xl text-white/10 group-hover:text-[var(--color-primary)] transition-colors">{a.annee}</span>
                <span class="text-sm font-bold uppercase tracking-widest text-white/50 group-hover:text-white transition-colors">Résultats officiels</span>
              </div>
              <svg class="w-5 h-5 text-white/20 group-hover:text-[var(--color-primary)] transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )

  // ─── CONTACT ─────────────────────────────────────────────
  if (section._type === 'sectionContact') return (
    <section class="py-24 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div class="reveal">
            <span class="section-label">{section.titre || 'Contact'}</span>
            <span class="deco-line"></span>
            <h2 class="section-title">Parlons de <span>votre projet</span></h2>
            <div class="space-y-4 mt-8">
              {section.email && (
                <a href={`mailto:${section.email}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors group">
                  <div class="w-10 h-10 rounded flex items-center justify-center border border-white/10 group-hover:border-[var(--color-primary)] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <span class="text-sm font-medium">{section.email}</span>
                </a>
              )}
              {section.telephone && (
                <a href={`tel:${section.telephone}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors group">
                  <div class="w-10 h-10 rounded flex items-center justify-center border border-white/10 group-hover:border-[var(--color-primary)] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <span class="text-sm font-medium">{section.telephone}</span>
                </a>
              )}
            </div>
          </div>
          <div class="reveal reveal-delay-2">
            <form name="contact" method="POST" data-netlify="true" class="space-y-4">
              <input type="hidden" name="form-name" value="contact" />
              <div class="grid grid-cols-2 gap-4">
                <input type="text" name="nom" placeholder="Nom" required
                  class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
                <input type="email" name="email" placeholder="Email" required
                  class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
              </div>
              <input type="text" name="sujet" placeholder="Sujet"
                class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full" />
              <textarea name="message" placeholder="Votre message" rows="5" required
                class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-colors rounded-none w-full resize-none"></textarea>
              <button type="submit" class="btn-primary w-full justify-center">
                Envoyer le message
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  )

  // ─── BÉNÉVOLES ───────────────────────────────────────────
  if (section._type === 'sectionBenevoles') return (
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="reveal order-2 lg:order-1">
            <span class="section-label">Rejoindre l'aventure</span>
            <span class="deco-line"></span>
            <h2 class="section-title">{section.titre || 'Devenir <span>bénévole</span>'}</h2>
            {section.description && <p class="text-white/50 leading-relaxed mb-8 text-sm">{section.description}</p>}
            {section.lienInscription && (
              <a href={section.lienInscription} class="btn-primary" target="_blank">
                Je participe
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            )}
          </div>
          {section.image && (
            <div class="reveal reveal-delay-2 order-1 lg:order-2 overflow-hidden">
              <img
                src={urlFor(section.image).width(800).url()}
                alt="Bénévoles"
                class="w-full h-80 lg:h-96 object-cover"
              />
            </div>
          )}
        </div>
      </div>
    </section>
  )

  return null
})}
