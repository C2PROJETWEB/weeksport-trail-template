---
import { urlFor } from '../lib/sanity'
const { site, nav } = Astro.props
const logoUrl = site?.logo ? urlFor(site.logo).height(60).url() : (site?.logoUrl || null)
const year = new Date().getFullYear()
---
<footer style="background: #0d0b12; border-top: 1px solid rgba(255,255,255,0.06)">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Col 1 : Logo + tagline -->
      <div class="flex flex-col gap-4">
        {logoUrl
          ? <img src={logoUrl} alt={site?.name} class="h-14 w-auto object-contain" />
          : <span class="font-display text-3xl tracking-wider text-white">{site?.name}</span>
        }
        <p class="text-sm text-white/40 leading-relaxed max-w-xs">
          Trail nocturne au cœur du Lac de Villerest — une aventure entre forêts, sentiers et reflets de lumière.
        </p>
        <div class="w-10 h-0.5 mt-1" style="background-color: var(--color-primary)"></div>
      </div>

      <!-- Col 2 : Liens rapides -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-[0.25em] mb-5" style="color: var(--color-primary)">Navigation</h4>
        <ul class="flex flex-col gap-2">
          {nav?.items?.map((item: any) => (
            <li>
              <a
                href={`/${item.slug}`}
                class="text-sm text-white/50 hover:text-white transition-colors"
              >{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3 : Contact + réseaux -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-[0.25em] mb-5" style="color: var(--color-primary)">Contact</h4>
        <ul class="flex flex-col gap-3 text-sm text-white/50">
          <li>
            <a href="/contact" class="hover:text-white transition-colors">Formulaire de contact</a>
          </li>
          <li>
            <a href="https://www.chronopuces.fr/trail-du-lac-de-villerest-2026" target="_blank" rel="noopener"
              class="hover:text-white transition-colors">
              Inscriptions — chronopuces.fr
            </a>
          </li>
          <li class="text-white/30 pt-2">Village Trail · Salle de la Papeterie<br/>Villerest, Loire</li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid rgba(255,255,255,0.05)">
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/20 tracking-widest uppercase">
        &copy; {year} Trail du Lac de Villerest — Tous droits réservés
      </p>
      <p class="text-xs text-white/20 tracking-widest uppercase">
        Une création originale&nbsp;
        <a href="https://www.c2projetweb.fr" target="_blank" rel="noopener"
          class="font-semibold hover:text-white transition-colors"
          style="color: var(--color-primary)">
          C2 Projet Web
        </a>
      </p>
    </div>
  </div>
</footer>
