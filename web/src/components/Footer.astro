---
import { urlFor } from '../lib/sanity'
const { site } = Astro.props
const logoUrl = site?.logo ? urlFor(site.logo).height(60).url() : (site?.logoUrl || null)
const year = new Date().getFullYear()
---
<footer class="border-t border-white/5 py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex flex-col items-center md:items-start gap-3">
        {logoUrl
          ? <img src={logoUrl} alt={site?.name} class="h-12 w-auto object-contain opacity-60 hover:opacity-100 transition-opacity" />
          : <span class="font-display text-2xl tracking-wider text-white/40">{site?.name}</span>
        }
        <p class="text-xs text-white/20 tracking-widest uppercase">&copy; {year} — Tous droits réservés</p>
      </div>

      <div class="flex items-center gap-2 text-xs text-white/20 tracking-widest uppercase">
        <span>Site réalisé par</span>
        <a href="https://www.weekandsport.com" target="_blank" rel="noopener"
          class="font-bold hover:text-white transition-colors" style="color: var(--color-primary)">
          WEEK&SPORT
        </a>
      </div>
    </div>
  </div>
</footer>
