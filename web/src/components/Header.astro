---
import { urlFor } from '../lib/sanity'
const { site, nav } = Astro.props
const logoUrl = site?.logo ? urlFor(site.logo).height(80).url() : (site?.logoUrl || null)
const items = nav?.items || []
---
<header id="header" class="fixed top-0 w-full z-50 transition-all duration-300 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0 group">
      {logoUrl
        ? <img src={logoUrl} alt={site?.name} class="h-12 w-auto object-contain transition-all duration-300 group-hover:scale-105" />
        : <span class="font-display text-2xl tracking-wider" style="color: var(--color-primary)">{site?.name}</span>
      }
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-1">
      {items.map((item) => (
        <div class="relative group">
          <a
            href={item.sousMenu?.length ? '#' : `/${item.slug || ''}`}
            class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-gray-600 hover:text-gray-900 transition-colors flex items-center gap-1"
          >
            {item.label}
            {item.sousMenu?.length > 0 && (
              <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="currentColor" viewBox="0 0 20 20">
                <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/>
              </svg>
            )}
          </a>
          {item.sousMenu?.length > 0 && (
            <div class="absolute top-full left-0 hidden group-hover:block pt-2 min-w-[200px]">
              <div class="bg-white border border-gray-200 rounded overflow-hidden shadow-xl">
                {item.sousMenu.map((sub) => (
                  <a href={`/${sub.slug}`} class="block px-5 py-3 text-xs font-bold uppercase tracking-widest text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-0">
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- CTA + burger -->
    <div class="flex items-center gap-4">
      {site?.heroCTA && site?.heroCTAUrl && (
        <a href={site.heroCTAUrl} class="hidden lg:inline-flex btn-primary text-xs py-3 px-6" target="_blank" rel="noopener">
          {site.heroCTA}
        </a>
      )}
      <button id="menu-toggle" class="lg:hidden w-10 h-10 flex flex-col justify-center items-center gap-1.5 group" aria-label="Menu">
        <span class="w-6 h-0.5 bg-gray-800 transition-all group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
        <span class="w-6 h-0.5 bg-gray-800 transition-all group-[.open]:opacity-0"></span>
        <span class="w-6 h-0.5 bg-gray-800 transition-all group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    {items.map((item) => (
      <div>
        <a href={`/${item.slug || ''}`} class="flex items-center justify-between px-6 py-4 text-xs font-bold uppercase tracking-widest text-gray-700 border-b border-gray-100 hover:bg-gray-50 transition-colors">
          {item.label}
        </a>
        {item.sousMenu?.map((sub) => (
          <a href={`/${sub.slug}`} class="block px-10 py-3 text-xs font-semibold text-gray-400 border-b border-gray-50 tracking-wider hover:text-gray-700 hover:bg-gray-50 transition-colors">
            {sub.label}
          </a>
        ))}
      </div>
    ))}
  </div>
</header>

<script>
  const header = document.getElementById('header')
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')

  // Scroll effect: just reinforce shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('shadow-md')
      header?.classList.remove('shadow-sm')
    } else {
      header?.classList.remove('shadow-md')
      header?.classList.add('shadow-sm')
    }
  })

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden')
    toggle.classList.toggle('open', !isOpen)
  })
</script>
