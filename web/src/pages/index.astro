---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Sections from '../components/Sections.astro'
import { getSite, getNavigation, getPage } from '../lib/sanity'

const siteSlug = import.meta.env.PUBLIC_SITE_SLUG
const [site, nav, homePage] = await Promise.all([
  getSite(siteSlug),
  getNavigation(siteSlug),
  getPage(siteSlug, 'accueil')
])
---
<BaseLayout site={site} nav={nav}>
  <Hero site={site} />
  {homePage?.sections && <Sections sections={homePage.sections} />}
</BaseLayout>
