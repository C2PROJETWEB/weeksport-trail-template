---
import BaseLayout from '../layouts/BaseLayout.astro'
import Sections from '../components/Sections.astro'
import { getSite, getNavigation, getPage, getPages } from '../lib/sanity'

export async function getStaticPaths() {
  const siteSlug = import.meta.env.PUBLIC_SITE_SLUG
  const pages = await getPages(siteSlug)
  return pages
    .filter(p => p.slug?.current !== 'accueil')
    .map(p => ({ params: { slug: p.slug.current } }))
}

const { slug } = Astro.params
const siteSlug = import.meta.env.PUBLIC_SITE_SLUG

const [site, nav, page] = await Promise.all([
  getSite(siteSlug),
  getNavigation(siteSlug),
  getPage(siteSlug, slug)
])

if (!page) return Astro.redirect('/404')
---
<BaseLayout site={site} nav={nav} title={`${page.title} — ${site?.name}`}>
  <div class="pt-20">
    {page.sections?.[0]?._type !== 'sectionEpreuves' && (
      <div class="relative py-20 overflow-hidden">
        {site?.heroImageUrl && (
          <div class="absolute inset-0 bg-cover bg-center bg-no-repeat"
            style={`background-image: url('${site.heroImageUrl}')`} />
        )}
        <div class="absolute inset-0"
          style="background: linear-gradient(135deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.6) 100%)" />
        <div class="absolute inset-y-0 left-0 w-1"
          style="background: linear-gradient(to bottom, transparent, var(--color-primary), transparent)" />
        <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12">
          <h1 class="font-display text-5xl md:text-7xl font-black uppercase text-white leading-none">{page.title}</h1>
          <div class="w-16 h-1 mt-4" style="background-color: var(--color-primary)"></div>
        </div>
      </div>
    )}
    <Sections sections={page.sections || []} />
  </div>
</BaseLayout>
